# ─── Secrets ─────────────────────────────────────────────
# Never commit real provider API keys. Commit a sanitized .env.example instead.
.env
.env.*
!.env.example

# ─── macOS ───────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes

# ─── Editors / IDEs ──────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-workspace

# ─── Node (only if you ever run `npx skills` locally) ────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/

# ─── Logs / caches / temp ────────────────────────────────
*.log
.cache/
tmp/
*.tmp
.playwright-cli/          # cmux/Playwright browser-automation session logs + snapshots
*.tsbuildinfo            # TypeScript incremental-build cache

# ─── Claude Code local (user-specific, not shipped) ──────
.claude/settings.local.json

# ─── Backups ─────────────────────────────────────────────
*.bak
*.orig

# ─── Legacy / archived docs (kept locally, not shipped) ──
# The original long-form index.html + side comparison/research docs live here.
legacy/

# ─── apps/flotion (the demo app the agent team builds) ───
apps/flotion/backend/flotion.db
apps/flotion/backend/.venv/
apps/flotion/frontend/dist/
apps/flotion/frontend/vite.config.js     # compiled from vite.config.ts (Vite reads the .ts directly)
apps/flotion/frontend/vite.config.d.ts
__pycache__/
*.pyc

# ─── Agent team runtime state (written at spawn / during a run) ──
# Ignore everything in .team/ except the README that documents it.
.team/*
!.team/README.md
