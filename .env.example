# API Keys for the agents an orchestrator kicks off inside cmux.
# Copy this file to .env and fill in your real keys:  cp .env.example .env
# .env is gitignored — never commit real keys.

# OpenRouter (https://openrouter.ai) — used by `pi --provider openrouter`
OPENROUTER_API_KEY="sk-or-v1-your-key-here"

# Anthropic (for Claude models / Claude Code via API key)
ANTHROPIC_API_KEY="sk-ant-your-key-here"

# OpenAI (for GPT models)
OPENAI_API_KEY="sk-your-key-here"

# Google Gemini
GEMINI_API_KEY="your-gemini-api-key-here"
